---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  /** When true, the site name renders as the page <h1> (homepage only). */
  isHome?: boolean;
}

const { isHome = false } = Astro.props;
---

<nav class="flex items-center justify-between">
  {
    isHome ? (
      <h1 class="site-name inline-block m-0">
        <a href="/">1xEngineer</a>
      </h1>
    ) : (
      <a href="/" class="site-name">1xEngineer</a>
    )
  }
  <div class="flex items-center gap-6">
    <a href="/" class="py-4">Home</a>
    <a href="/about" class="py-4">About</a>
    <ThemeToggle />
  </div>
</nav>
{
  isHome && (
    <p class="tagline">
      Hi 👋🏽, I am an Engineering Manager by trade. I have built software
      by leading a team of humans, and now I am learning to work with a team of
      agents.
    </p>
  )
}

<style>
  .site-name {
    font-size: 1.5rem;
    line-height: 1.2;
    font-weight: 600;
    /* Brand mark keeps Solarized magenta, as on the old site
       (4.21:1 light / 3.30:1 dark — large-text AA pass) */
    color: var(--color-magenta);
    text-decoration: none;
  }
  .site-name a {
    color: inherit;
    text-decoration: none;
  }
  .site-name:hover,
  .site-name a:hover {
    color: var(--color-link-hover);
  }
  .tagline {
    margin-top: 0.75rem;
    font-size: 0.9rem;
    color: var(--color-muted);
  }
</style>
