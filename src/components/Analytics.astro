---
// GoatCounter analytics — zero-prop component
// The site code comes from PUBLIC_GOATCOUNTER_CODE (set in Vercel, Production
// only). No fallback: builds without it (local dev, previews) render no
// analytics script, keeping those pageviews out of the stats.
const code = import.meta.env.PUBLIC_GOATCOUNTER_CODE;
---

{
  code && (
    <script
      is:inline
      data-goatcounter={`https://${code}.goatcounter.com/count`}
      async
      src="//gc.zgo.at/count.js"
    />
  )
}
