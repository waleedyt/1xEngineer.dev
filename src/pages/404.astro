---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found - 1xEngineer" description="The page you are looking for does not exist.">
  <div class="notfound">
    <h1>404 — Page Not Found</h1>
    <p>Oops! This page wandered off. Maybe it is out hiking the Margallah trails ⛰.</p>
    <p><a href="/">Head back home</a></p>
  </div>
</BaseLayout>

<style>
  .notfound {
    padding-block: 2rem;
  }
  .notfound p {
    color: var(--color-fg);
    margin-block: 1rem;
  }
</style>
